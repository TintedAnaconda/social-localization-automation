# Copying is automatic via setup script.
# Only edit this file if you need to change settings.

# Replace below only if instructed
N8N_ENCRYPTION_KEY=replace_with_your_own_key

# n8n basic settings
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Timezone
GENERIC_TIMEZONE=America/Los_Angeles
TZ=America/Los_Angeles

# Security
N8N_SECURE_COOKIE=false

# Optional: set a fixed encryption key for credentials
# Generate once and keep stable for the team member's machine
N8N_ENCRYPTION_KEY=replace_with_your_own_long_random_string

# Optional: disable templates if desired
N8N_TEMPLATES_ENABLED=false