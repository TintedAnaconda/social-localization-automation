# Copying is automatic via setup script.
# Only edit this file if you need to change settings.

# DO NOT set N8N_ENCRYPTION_KEY for local setup.
# n8n will generate and manage this automatically per machine.

# n8n basic settings
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Timezone
GENERIC_TIMEZONE=America/Los_Angeles
TZ=America/Los_Angeles

# Security
N8N_SECURE_COOKIE=false

# Optional: disable templates if desired
N8N_TEMPLATES_ENABLED=false